# ClickHouse Cloud service that will own ClickPipes resources.
clickhouse_organization_id = "00000000-0000-0000-0000-000000000000"
clickhouse_cloud_api_key    = "REPLACE_ME"
clickhouse_cloud_api_secret = "REPLACE_ME"
clickhouse_service_id       = "00000000-0000-0000-0000-000000000000"
clickhouse_service_iam_role = "arn:aws:iam::123456789012:role/ClickHouseAccessRole"

# AWS account used by the ClickPipes consumer VPC.
clickpipes_consumer_aws_account_id = "123456789012"

# Source MSK region. Set supported_regions to the ClickPipes service region for
# cross-region PrivateLink, or leave it empty for same-region consumers.
region            = "eu-central-1"
supported_regions = ["eu-west-1"]

resource_prefix = "cp-msk-vpce"

# A one-minute interval usually costs $0 within AWS free tiers and less than
# approximately $0.30 per cluster per month without them.
broker_target_reconciliation_schedule_expression = "rate(1 minute)"
broker_target_reconciler_alarm_actions             = []

topic_name = "clickpipes-demo"

# Enable only after the topic exists and contains records.
create_clickpipe  = false
consumer_group    = "clickpipes-demo"
destination_table = "msk_vpce_demo"

columns = [
  { name = "id", type = "UInt64" },
  { name = "payload", type = "String" },
]

sorting_key = ["id"]
